# 复制为本目录下的 server.env 后填写（勿提交仓库）。
# Docker Compose 使用 KEY=VALUE 格式，不要写 export。
#
# 与 docker/docker-compose.server.yml（或仓库根目录 docker-compose.server.yml）一起用时：
#   - MySQL 在宿主机：DB_URL 用 host.docker.internal
#   - Qdrant 仅由 compose 提供：UIGPT_RAG_QDRANT_URL=http://qdrant:6333（勿写 localhost / host.docker.internal）
#   - 若启用 Qdrant API Key：同目录 cp qdrant.env.example qdrant.env 并填写，与本文件 UIGPT_RAG_QDRANT_API_KEY 一致
# 启动：docker compose -f docker/docker-compose.server.yml pull && docker compose -f docker/docker-compose.server.yml up -d

# ---------- 必填 ----------
# JWT，UTF-8 至少约 32 字节
UIGPT_JWT_SECRET=

# 数据库（后端在容器内不要用 127.0.0.1）
# MySQL 在宿主机、映射 3306 时示例：
DB_URL=jdbc:mysql://host.docker.internal:3306/uigpt?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=

# 对话：通义千问（全局默认 Key；若 chat_models.api_key_cipher 有值则优先用模型专用 Key）
DASHSCOPE_API_KEY=

# 第三方登录成功后跳转的前端地址（与浏览器地址栏一致；走 80 时一般不带端口）
UIGPT_OAUTH_FRONTEND_REDIRECT=https://你的域名/auth/callback

# ---------- 可选：解密库内模型专用 Key 密文 ----------
# UIGPT_MODEL_KEY_MASTER=

# ---------- 知识库 RAG（与 compose 中的 qdrant 服务配合）----------
# 不用知识库时保持 false；要用则 true，并填写向量化服务（OpenAI 兼容 /v1）。
# 仅在 Qdrant 配置了 QDRANT__SERVICE__API_KEY 时填写，且与之一致
UIGPT_RAG_COLLECTION=uigpt_kb

# 向量化（示例为 API易 OpenAI 兼容地址；按你实际网关修改）
UIGPT_RAG_EMBEDDING_BASE_URL=https://api.apiyi.com/v1
UIGPT_RAG_EMBEDDING_MODEL=text-embedding-3-small

# （高级）若 Qdrant 不在 compose 内、单独跑在宿主机：UIGPT_RAG_QDRANT_URL=http://host.docker.internal:6333
