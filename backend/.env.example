# 本地机密配置：复制本文件为「.env」并填写真实值（.env 已被 Git 忽略）
# 启动：./start-dev.sh 或在「已 source .env 的终端」内执行 mvn spring-boot:run
# 任意工作目录启动（含 Docker）时可设置：UIGPT_DOTENV_FILE=/绝对路径/backend/.env
#
# 注意：KEY=value 两侧不要多余空格；值末尾不要留空格/回车
# 若在 shell/IDE 里 export 过空的 APIYI_API_KEY= ，会盖住 backend/.env；请 unset 该变量或改为非空（后端已优先用文件里的非空值）

# 腾讯云 COS（控制台 → API 密钥管理：SecretId 一般以 AKID 开头；SecretKey 为长串，勿填反）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
# 可选：CDN/自定义域名，末尾不要斜杠；留空则用默认 https://{bucket}.cos.{region}.myqcloud.com
# COS_PUBLIC_URL_PREFIX=
# 启动时 HeadBucket（默认 false）；子账号策略未包含 HeadBucket 时请保持 false
# COS_VERIFY_BUCKET_ON_START=false
# 私有桶下图 URL 预签名有效期（秒），默认 86400（24h）；列表接口每次刷新签名
# COS_PRESIGNED_URL_EXPIRY_SECONDS=86400

# APIYi：填写 APIYI_API_KEY 即可（对话默认经 APIYi + 文生图）；亦可使用 UIGPT_APIYI_API_KEY；APIYI_IMAGE_ENABLED 可选保留
# APIYI_IMAGE_ENABLED=false
# APIYI_API_KEY=
# UIGPT_APIYI_API_KEY=
# APIYI_BASE_URL=https://api.apiyi.com
# APIYI_IMAGE_MODEL=gpt-image-2-all
# 锁尺寸高质量：gpt-image-2-vip（须使用文档 30 档 size；后端已按面板比例映射 2K/4K）
# APIYI_IMAGE_MODEL=gpt-image-2-vip
# generations/edits 响应：url（默认 R2，宜服务端下载落库）| b64_json
# APIYI_GENERATIONS_RESPONSE_FORMAT=url
# VIP size 档位：1k（Fast）| 2k（Recommended）| 4k（Detail）
# APIYI_VIP_SIZE_TIER=2k
# 高速文生图加权轮流：true 时在 GPT(generations) 与 Gemini 间按权重交替；false=仅用 generations
# APIYI_ROTATE_TTI=true
# 权重比默认 3:1（GPT 约 75%）；例：4:1 → APIYI_TTI_OPENAI_WEIGHT=4 APIYI_TTI_GEMINI_WEIGHT=1
# APIYI_TTI_OPENAI_WEIGHT=3
# APIYI_TTI_GEMINI_WEIGHT=1
# APIYI_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# APIYI_GEMINI_IMAGE_SIZE=2K
#
# APIYi「识图」：登录用户上传参考图时先走视觉模型摘要（与高速文生图共用 APIYI_API_KEY）
# APIYI_VISION_ENABLED=true
# APIYI_VISION_MODEL=gpt-4.1-mini
# APIYI_VISION_MAX_TOKENS=1200
#
# 「高级」主对话走 API易热门模型：库表 chat_models 增加启用行，api_model_code 填文档模型 ID（如 gpt-4.1、gemini-2.5-pro），
# base_url=https://api.apiyi.com/v1，provider=apiyi；密钥写入 api_key_cipher（EncryptModelApiKeyCli）或与全局 OPENAI_API_KEY 共用则密文留空。
# 已有库须执行 docs/migrate-incremental-columns.sql 补齐 chat_models.base_url 列。

# JWT（登录令牌签名）
# UIGPT_JWT_SECRET=

# MySQL（按需）
# DB_PASSWORD=
#
# 并发（多用户同时 SSE 对话 / 下载出图 URL）：可按机器内存与 MySQL max_connections 调大
# UIGPT_HTTP_CLIENT_WORKER_THREADS=64
# DB_POOL_MAX=32
# DB_POOL_MIN_IDLE=8
# TOMCAT_THREADS_MAX=200
# TOMCAT_MAX_CONNECTIONS=10000
