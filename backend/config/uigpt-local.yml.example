# 复制为 config/uigpt-local.yml（已 .gitignore）
# MySQL：须设置 DB_NAME、DB_USERNAME；DB_PASSWORD 可选空；可选 DB_HOST；DB_PORT 未设置时默认 3306
# 勿在本文件写入数据库密码
#
# Redis：限流、JWT 黑名单；默认 localhost:6379，可用 REDIS_HOST / REDIS_PORT 覆盖。
# 仅当 Redis 启用了 requirepass 时再配置密码，例如：
# spring:
#   data:
#     redis:
#       password: "你的密码"
# 或使用环境变量：SPRING_DATA_REDIS_PASSWORD（勿对无密码实例设空密码变量）

uigpt:
  jwt:
    secret: "00000000000000000000000000000000"
  # 注册：Google reCAPTCHA v3（可选，亦可用环境变量）
  # recaptcha:
  #   enabled: true
  #   site-key: "你的站点密钥"
  #   secret-key: "你的服务端密钥"
  #   min-score: 0.5
  # register-rate-limit:
  #   max-per-hour: 2
  #   max-per-24-hours: 3
  # 通义千问密钥请用环境变量 DASHSCOPE_API_KEY（或 QWEN_API_KEY / QIANWEN_API_KEY 等，见 application.yml）
  # 访客未登录对话：配置 QIANWEN_API_KEY 时走 uigpt.guest-chat（默认 qwen-turbo + DashScope 兼容地址）
