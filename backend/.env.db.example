# 本地开发：复制为本目录下的 .env.db 后按需修改（.env.db 已 gitignore，勿提交）
#
#   cp .env.db.example .env.db
#
# Spring Boot 读的是「进程环境变量」，不会自动读 .env 文件；请在启动后端前执行：
#   source /home/dataease/uigpt/backend/.env.db
# 若已在 ~/.bashrc 里加了 source 行，新开终端会自动加载。
#
# 常见报错 Access denied … (using password: NO)：说明后端没用上密码。
# 多数 Linux 上 MySQL 的 root 必须带密码，请在「本文件复制后的 .env.db」里填写：
#   export DB_PASSWORD='你的密码'
# 然后在运行 mvn spring-boot:run 的终端先执行：source backend/.env.db
#
# —— 方式 A（推荐）：一条 JDBC URL + 账号密码 ——
# export DB_URL='jdbc:mysql://127.0.0.1:3306/uigpt?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false'
# export DB_USERNAME='root'
# export DB_PASSWORD='你的密码'
# 也可使用 Spring 约定名：SPRING_DATASOURCE_URL / SPRING_DATASOURCE_USERNAME / SPRING_DATASOURCE_PASSWORD
#
# —— 方式 B：主机、端口、库名拆分（未设置 DB_URL 时生效）——

export DB_HOST=localhost
export DB_PORT=3306
export DB_NAME=uigpt
export DB_USERNAME=root
export DB_PASSWORD='你的MySQL密码'

# 对话密钥请写在 config/runtime-local.properties（见 runtime-local.properties.example），Spring 会自动加载，勿把密钥提交仓库。
#
# 若使用库表 chat_models.api_key_cipher 存储各模型 Key，还需配置解密主密钥（与加密 CLI 相同）：
# export UIGPT_MODEL_KEY_MASTER='你的主密钥'
